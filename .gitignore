# ===========================================================================
# Pagkamakabayan ay Maurag — .gitignore
# Static, serverless site (vanilla HTML/CSS/JS, no build step).
# Source assets in custom/ and assets/ are intentionally tracked.
# ===========================================================================

# ---------- Operating System ----------
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
ehthumbs_vista.db
$RECYCLE.BIN/
System Volume Information/
.AppleDouble
.LSOverride
.Spotlight-V100
.Trashes
.fseventsd
.DocumentRevisions-V100

# ---------- Windows ----------
*.lnk
Thumbs.db
ntuser.dat
NTUSER.DAT
ntuser.dat.LOG1
ntuser.dat.LOG2
*.stackdump

# ---------- Editor / IDE ----------
.vscode/
.idea/
*.swp
*.swo
*~
*.swn
*.swo
*.bak
*.tmp
*.temp
*.orig
*.rej
*.log
.vscode-test/
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace
.code-workspace

# ---------- Logs & debug output ----------
*.log
*.logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
debug.log
package-lock-debug.log

# ---------- Temp / cached files ----------
*.tmp
*.temp
*.cache
.cache/
*.bak
*.bkp
*.old
*~
.tmp/
temp/
tmp/
.sass-cache/
.local/

# ---------- Node / JS tooling (if added later) ----------
node_modules/
npm-debug.log*
yarn-error.log*
yarn-debug.log*
.pnp/
.pnp.js
.yarn/
.eslintcache
.stylelintcache
.npm
*.tsbuildinfo
next/
dist/
build/
out/

# ---------- Package manager lockfiles (optional) ----------
# Custom art + manifest are tracked; only generated JS lockfiles are ignored.
package-lock.json
yarn.lock
pnpm-lock.yaml

# ---------- Python (for optional local `http.server`) ----------
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# ---------- Coverage / test outputs ----------
coverage/
.nyc_output/
reports/
test-results/

# ---------- Env / secrets ----------
.env
.env.*
*.pem
*.key
secrets.json

# ---------- Kilo / agent metadata (machine-local) ----------
.kilo/agent-manager.json
.kilo/package-lock.json
